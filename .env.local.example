# HushhTech – Local development env example
# Copy this file to `.env.local` and fill in real values.
# NOTE: `.env.local` is git-ignored via `*.local` in .gitignore – do NOT commit real secrets.

# =====================================================
# Supabase Configuration
# =====================================================
# (Vite exposes only VITE_* variables to the client)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_REDIRECT_URL=http://localhost:5173/auth/callback

# Optional public client config used by older components.
VITE_NDA_GENERATION_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/nda-generate
VITE_GUEST_MODE_ACCESS_TOKEN=
VITE_MARKET_SUPABASE_URL=https://YOUR_MARKET_PROJECT_REF.supabase.co
VITE_MARKET_SUPABASE_KEY=YOUR_MARKET_SUPABASE_ANON_KEY

# =====================================================
# Apple OAuth maintenance (SERVER/SCRIPT SIDE ONLY)
# =====================================================
# These are used by src/scripts/generate_apple_secret.sh.
# Do NOT prefix these with VITE_.
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
APPLE_CLIENT_ID=YOUR_APPLE_SERVICES_ID
APPLE_KEY_ID=YOUR_SIGN_IN_WITH_APPLE_KEY_ID
# Optional. If omitted, the generator uses ~/.private_keys/AuthKey_${APPLE_KEY_ID}.p8
APPLE_KEY_FILE_PATH=/absolute/path/to/AuthKey_YOUR_SIGN_IN_WITH_APPLE_KEY_ID.p8

# =====================================================
# KYC A2A Network Configuration
# =====================================================
# Environment: 'development' | 'staging' | 'production'
VITE_KYC_ENV=development

# KYC Agent API Base URL
# Development/Staging: Uses Supabase Edge Functions
# Production: May use custom domain
VITE_KYC_API_BASE=https://YOUR_PROJECT_REF.supabase.co/functions/v1/kyc-agent-a2a

# Demo Mode: When 'true', enables test users and detailed logging
# Set to 'false' for production to hide demo hints
VITE_KYC_DEMO_MODE=true

# Test Bank IDs (comma-separated) - Only used in development
# These banks are seeded in the database migration
VITE_KYC_TEST_BANK_IDS=demo_bank_alpha,demo_fintech_beta,demo_neobank_gamma

# =====================================================
# ⚠️ PRODUCTION DEPLOYMENT
# =====================================================
# For production, update these values:
#   VITE_KYC_ENV=production
#   VITE_KYC_DEMO_MODE=false
#   VITE_KYC_API_BASE=https://your-production-domain.com/functions/v1/kyc-agent-a2a
#
# Production API keys should be stored in:
#   - Supabase Edge Function secrets (for server-side)
#   - Vercel environment variables (for deployment)
#
# NEVER commit production keys to git!
# =====================================================

# =====================================================
# Stock Market Data (Finnhub)
# =====================================================
# Finnhub API key for real-time stock quotes
# Get your free API key at: https://finnhub.io/
VITE_FINNHUB_API_KEY=YOUR_FINNHUB_API_KEY

# =====================================================
# OpenAI Configuration
# =====================================================
# OpenAI API key (for investor profile generation)
# Used SERVER-SIDE in serverless API function /api/generate-investor-profile.js
# This is NOT exposed to the client (no VITE_ prefix) for security
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
NEXT_PUBLIC_OPENAI_URL=api.openai.com

# Gmail SMTP credentials for notification and metrics emails
GMAIL_USER=notifications@example.com
GMAIL_APP_PASSWORD=YOUR_GMAIL_APP_PASSWORD

# Google Wallet pass generation
GOOGLE_WALLET_ISSUER_ID=YOUR_GOOGLE_WALLET_ISSUER_ID
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=wallet-service-account@YOUR_PROJECT.iam.gserviceaccount.com
GOOGLE_WALLET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_GOOGLE_WALLET_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
GOOGLE_WALLET_CLASS_SUFFIX=hushh_gold_investor_v1
GOOGLE_WALLET_ALLOWED_ORIGINS=https://hushhtech.com,https://www.hushhtech.com

# Analytics and metrics embeds
LOOKER_STUDIO_EMBED_URL=https://lookerstudio.google.com/embed/reporting/YOUR_REPORT
GA4_PROPERTY_ID=123456789
GA4_ALLOWED_HOSTNAMES=hushhtech.com,www.hushhtech.com

# =====================================================
# iOS TestFlight Deployment (macOS only)
# =====================================================
# These are used by the ios-deploy.sh script for automated TestFlight uploads.
# You need to create an App Store Connect API Key first:
# https://appstoreconnect.apple.com/access/api
#
# Key ID: Found in the Keys table after creating your key
# Issuer ID: Found at the top of the Keys page
#
# The .p8 key file should be placed in: ~/.private_keys/AuthKey_{KEY_ID}.p8
# Never keep the real .p8 file inside this repo.
#
# See IOS_TESTFLIGHT_UPLOAD.md for detailed setup instructions.
APP_STORE_API_KEY_ID=YOUR_KEY_ID
APP_STORE_ISSUER_ID=YOUR_ISSUER_ID

# =====================================================
# Voice Agent Configuration (Hushh Intelligence)
# =====================================================
# n8n Webhook URL for voice agent processing
# Local development: http://localhost:5678/webhook/voice-agent
# Production: Configure in n8n cloud or self-hosted
VITE_N8N_WEBHOOK_URL=http://localhost:5678/webhook/voice-agent

# OpenAI Realtime API Key (for voice-to-voice)
# DEV ONLY. Do not set this in production builds unless you intentionally want
# the browser bundle to contain the key.
VITE_OPENAI_API_KEY=YOUR_DEV_ONLY_OPENAI_API_KEY
VITE_ALLOW_INSECURE_BROWSER_LLM=false

# Voice Agent Edge Function URL
VITE_VOICE_AGENT_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/voice-agent-turn

# =====================================================
# Gemini API Configuration
# =====================================================
# Google Gemini API keys for active AI experiences such as Kai and Studio.
#
# DEV / TRANSITIONAL SETUP:
# Any Gemini key under VITE_* is visible to the browser bundle.
# Keep these only for local debugging or temporary browser-only flows.
#
# Create API keys at: https://aistudio.google.com/apikey
# - Create 4 separate API keys for redundancy
# - Name them clearly so rotation is easy to manage
# - All keys should have NO expiry date
#
# Primary API key (required)
VITE_GEMINI_API_KEY=YOUR_DEV_ONLY_GEMINI_API_KEY

# Fallback API keys (optional but recommended for production)
# These are also browser-visible when set under VITE_*
VITE_GEMINI_API_KEY_FALLBACK_1=YOUR_DEV_ONLY_GEMINI_FALLBACK_KEY_1
VITE_GEMINI_API_KEY_FALLBACK_2=YOUR_DEV_ONLY_GEMINI_FALLBACK_KEY_2
VITE_GEMINI_API_KEY_FALLBACK_3=YOUR_DEV_ONLY_GEMINI_FALLBACK_KEY_3

# TIP: Do not add these to production unless you accept browser exposure:
#   - VITE_GEMINI_API_KEY
#   - VITE_GEMINI_API_KEY_FALLBACK_1
#   - VITE_GEMINI_API_KEY_FALLBACK_2
#   - VITE_GEMINI_API_KEY_FALLBACK_3

# =====================================================
# Plaid Financial Verification (Pre-KYC)
# =====================================================
# Plaid API credentials for Balance, Assets & Investments
# Get your keys at: https://dashboard.plaid.com/
#
# These are the env vars used by Supabase Edge Functions:
PLAID_CLIENT_ID=YOUR_PLAID_CLIENT_ID
PLAID_SECRET=YOUR_PLAID_SECRET
#
# Environment: 'sandbox' | 'production'
# IMPORTANT: Only 'sandbox' and 'production' are valid Plaid API hosts.
# Using any other value will cause API calls to fail.
PLAID_ENV=sandbox
#
# OAuth Redirect URI for the web client (must be registered in Plaid Dashboard)
# Local:      http://localhost:5173/onboarding/financial-link
# Production: https://hushhtech.com/onboarding/financial-link
# NOTE: Both https://hushhtech.com and https://www.hushhtech.com redirect URIs
#       must be registered in the Plaid Dashboard to handle www vs non-www access.
VITE_PLAID_REDIRECT_URI=http://localhost:5173/onboarding/financial-link
#
# Supabase service role key (for server-side writes from API routes)
# Get from: Supabase Dashboard > Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# n8n Configuration (for docker/n8n)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_secure_password
N8N_ENCRYPTION_KEY=your_32_char_encryption_key_here
